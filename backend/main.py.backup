# ============= REAL-TIME TRACKING =============

@app.websocket("/ws/tracking/{driver_id}")
async def tracking_websocket(websocket: WebSocket, driver_id: str):
    """
    WebSocket endpoint for real-time GPS tracking
    Driver app sends location updates here
    """
    await manager.connect(websocket, driver_id)
    try:
        while True:
            # Receive location update from driver
            data = await websocket.receive_json()
            
            # Broadcast to all connected dashboards
            await manager.broadcast({
                "type": "location_update",
                "driver_id": driver_id,
                "lat": data.get("lat"),
                "lng": data.get("lng"),
                "timestamp": datetime.utcnow().isoformat(),
                "speed": data.get("speed", 0),
                "heading": data.get("heading", 0)
            })
            
    except WebSocketDisconnect:
        manager.disconnect(driver_id)

@app.websocket("/ws/dashboard")
async def dashboard_websocket(websocket: WebSocket):
    """
    WebSocket endpoint for dashboard to receive real-time updates
    """
    await manager.connect(websocket, f"dashboard_{id(websocket)}")
    try:
        while True:
            await asyncio.sleep(1)  # Keep connection alive
    except WebSocketDisconnect:
        manager.disconnect(f"dashboard_{id(websocket)}")

