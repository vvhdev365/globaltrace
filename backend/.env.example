# Backend Configuration
DEBUG=false
SECRET_KEY=your-secret-key-change-this-in-production
API_PORT=8000

# Database Configuration
DATABASE_URL=postgresql+asyncpg://logistics_user:logistics_pass@db:5432/logistics_db
POSTGRES_USER=logistics_user
POSTGRES_PASSWORD=logistics_pass
POSTGRES_DB=logistics_db

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# External APIs
OSRM_URL=http://osrm:5000
MAPBOX_ACCESS_TOKEN=your-mapbox-token-if-needed

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Email Configuration (Optional - for Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Monitoring
SENTRY_DSN=your-sentry-dsn-if-needed

# Feature Flags
ENABLE_ML_PREDICTIONS=false
ENABLE_REAL_TIME_TRACKING=true
